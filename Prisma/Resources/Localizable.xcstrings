    "onboarding.plus.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reading news is always free. Prisma+ only enables features with real costs like AI summaries and smart organization."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leer noticias será siempre gratis. Prisma+ solo activa funciones con coste real como IA, resúmenes y organización inteligente."
          }
        }
      }
    },
